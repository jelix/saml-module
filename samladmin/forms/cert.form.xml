<?xml version="1.0" encoding="utf-8"?>
<form xmlns="http://jelix.org/ns/forms/1.1">

	<input ref="certCountryName" type="string" required="true">
		<label locale="samladmin~admin.spconfig.form.cert.countryName.label"/>
		<help locale="samladmin~admin.spconfig.form.cert.countryName.help"/>
	</input>

	<input ref="certStateOrProvinceName" type="string" required="true">
		<label locale="samladmin~admin.spconfig.form.cert.stateOrProvinceName.label"/>
	</input>

	<input ref="certLocalityName" type="string">
		<label locale="samladmin~admin.spconfig.form.cert.localityName.label"/>
		<help locale="samladmin~admin.spconfig.form.cert.localityName.help"/>
	</input>

	<input ref="certOrganizationName" type="string" required="true">
		<label locale="samladmin~admin.spconfig.form.cert.organizationName.label"/>
		<help locale="samladmin~admin.spconfig.form.cert.organizationName.help"/>
	</input>

	<input ref="certOrganizationalUnitName" type="string">
		<label locale="samladmin~admin.spconfig.form.cert.organizationalUnitName.label"/>
	</input>

	<input ref="certCommonName" type="string" required="true">
		<label locale="samladmin~admin.spconfig.form.cert.commonName.label"/>
		<help locale="samladmin~admin.spconfig.form.cert.commonName.help"/>
	</input>

	<menulist ref="certDaysValidity"  required="true">
		<label locale="samladmin~admin.spconfig.form.cert.yearsValidity.label"/>
        <item value="365">1</item>
        <item value="730">2</item>
        <item value="1095">3</item>
        <item value="1460">4</item>
        <item value="1825">5</item>
	</menulist>

</form>
