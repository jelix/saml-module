<?xml version="1.0" encoding="utf-8"?>
<form xmlns="http://jelix.org/ns/forms/1.1">

    <input ref="login" type="string" required="true">
        <label locale="samladmin~admin.attrmapping.form.login.label"/>
    </input>

    <group ref="attrsgroup">
        <label locale="samladmin~admin.attrmapping.form.attrsgroup.label" />
    </group>

    <group ref="groupsfromsaml" withcheckbox="true">
        <label locale="samladmin~admin.attrmapping.form.groupsfromsaml.label"/>
        <input ref="groupsfromsamlattr" type="string" required="true">
            <label locale="samladmin~admin.attrmapping.form.groupsfromsamlattr.label"/>
            <help locale="samladmin~admin.attrmapping.form.groupsfromsamlattr.help"/>
        </input>
        <input ref="groupsfromsamlprefix" type="string">
            <label locale="samladmin~admin.attrmapping.form.groupsfromsamlprefix.label"/>
            <help locale="samladmin~admin.attrmapping.form.groupsfromsamlprefix.help"/>
        </input>
        <checkbox ref="groupsfromsamldropprefix">
            <label locale="samladmin~admin.attrmapping.form.groupsfromsamldropprefix.label"/>
            <help locale="samladmin~admin.attrmapping.form.groupsfromsamldropprefix.help"/>
        </checkbox>
    </group>

    <checkbox ref="automaticAccountCreation">
        <label locale="samladmin~admin.attrmapping.form.automaticAccountCreation.label"/>
    </checkbox>

    <checkbox ref="allowSAMLAccountToUseLocalPassword">
        <label locale="samladmin~admin.attrmapping.form.allowSAMLAccountToUseLocalPassword.label"/>
    </checkbox>

    <radiobuttons ref="forceSAMLAuthOnLoginPage">
        <label locale="samladmin~admin.attrmapping.form.forceSAMLAuthOnLoginPage.title"/>
        <item value="form" locale="samladmin~admin.attrmapping.form.forceSAMLAuthOnLoginPage.form.label"/>
        <item value="saml" locale="samladmin~admin.attrmapping.form.forceSAMLAuthOnLoginPage.saml.label"/>
    </radiobuttons>


    <radiobuttons ref="forceSAMLAuthOnPrivatePage">
        <label locale="samladmin~admin.attrmapping.form.forceSAMLAuthOnPrivatePage.title"/>
        <item value="form" locale="samladmin~admin.attrmapping.form.forceSAMLAuthOnPrivatePage.form.label"/>
        <item value="saml" locale="samladmin~admin.attrmapping.form.forceSAMLAuthOnPrivatePage.saml.label"/>
    </radiobuttons>

    <radiobuttons ref="redirectionAfterLogin">
        <label locale="samladmin~admin.attrmapping.form.redirectionAfterLogin.label"/>
    </radiobuttons>

    <radiobuttons ref="localLogoutOnly">
        <label locale="samladmin~admin.attrmapping.form.localLogoutOnly.title"/>
        <item value="saml" locale="samladmin~admin.attrmapping.form.localLogoutOnly.saml.label"/>
        <item value="local" locale="samladmin~admin.attrmapping.form.localLogoutOnly.local.label"/>
    </radiobuttons>

    <submit ref="_submit">
        <label locale="jelix~ui.buttons.save"/>
    </submit>
</form>
